{
  "name": "loom-workbench",
  "displayName": "Loom Workbench",
  "description": "Side-panel UI and debug commands for the Loom runtime.",
  "version": "0.1.2",
  "publisher": "ajoshp",
  "preview": true,
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joshpolansky/LoomUI.git"
  },
  "bugs": {
    "url": "https://github.com/Joshpolansky/LoomUI/issues"
  },
  "homepage": "https://github.com/Joshpolansky/LoomUI#readme",
  "keywords": [
    "loom",
    "plc",
    "automation",
    "control-systems",
    "realtime",
    "embedded"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.modules",
          "name": "Modules",
          "icon": "media/loom.svg"
        },
        {
          "id": "loom.scheduler",
          "name": "Scheduler",
          "icon": "media/loom.svg"
        },
        {
          "id": "loom.bus",
          "name": "Bus",
          "icon": "media/loom.svg"
        },
        {
          "id": "loom.mappings",
          "name": "I/O Mappings",
          "icon": "media/loom.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "loom.runtime.start",
        "title": "Loom: Start Runtime",
        "icon": "$(debug-start)"
      },
      {
        "command": "loom.runtime.stop",
        "title": "Loom: Stop Runtime",
        "icon": "$(debug-stop)"
      },
      {
        "command": "loom.runtime.restart",
        "title": "Loom: Restart Runtime",
        "icon": "$(debug-restart)"
      },
      {
        "command": "loom.runtime.debug",
        "title": "Loom: Debug Runtime (Native)",
        "icon": "$(debug-alt)"
      },
      {
        "command": "loom.runtime.attach",
        "title": "Loom: Attach Native Debugger",
        "icon": "$(debug-alt)"
      },
      {
        "command": "loom.modules.openSource",
        "title": "Loom: Open Module Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "loom.runtime.toggle",
        "title": "Loom: Toggle Runtime"
      },
      {
        "command": "loom.runtime.connect",
        "title": "Loom: Connect to Runtime..."
      },
      {
        "command": "loom.runtime.install",
        "title": "Loom: Install Loom Runtime...",
        "icon": "$(cloud-download)"
      },
      {
        "command": "loom.runtime.selectProfile",
        "title": "Loom: Select Runtime Profile...",
        "icon": "$(versions)"
      },
      {
        "command": "loom.runtime.uninstall",
        "title": "Loom: Uninstall Loom Runtime...",
        "icon": "$(trash)"
      },
      {
        "command": "loom.modules.refresh",
        "title": "Loom: Refresh Modules",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.modules.manage",
        "title": "Loom: Manage Modules...",
        "icon": "$(settings-gear)"
      },
      {
        "command": "loom.modules.openDetail",
        "title": "Loom: Inspect Module in Variables View"
      },
      {
        "command": "loom.modules.inspect",
        "title": "Loom: Watch Modules (Variables View)",
        "icon": "$(search)"
      },
      {
        "command": "loom.modules.inspect.refresh",
        "title": "Loom: Refresh Inspector",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.modules.setValue",
        "title": "Loom: Set Value..."
      },
      {
        "command": "loom.modules.instantiate",
        "title": "Loom: Instantiate Module...",
        "icon": "$(add)"
      },
      {
        "command": "loom.modules.remove",
        "title": "Loom: Remove Module",
        "icon": "$(trash)"
      },
      {
        "command": "loom.modules.reload",
        "title": "Loom: Reload Module",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.modules.saveConfig",
        "title": "Loom: Save Module Config"
      },
      {
        "command": "loom.modules.loadConfig",
        "title": "Loom: Load Module Config from Disk"
      },
      {
        "command": "loom.modules.upload",
        "title": "Loom: Upload Module..."
      },
      {
        "command": "loom.modules.newProject",
        "title": "Loom: New Module Project...",
        "icon": "$(new-folder)"
      },
      {
        "command": "loom.bus.callService",
        "title": "Loom: Call Bus Service..."
      },
      {
        "command": "loom.scheduler.refresh",
        "title": "Loom: Refresh Scheduler",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.scheduler.newClass",
        "title": "Loom: New Scheduler Class...",
        "icon": "$(add)"
      },
      {
        "command": "loom.scheduler.editPeriod",
        "title": "Loom: Edit Period..."
      },
      {
        "command": "loom.scheduler.editPriority",
        "title": "Loom: Edit Priority..."
      },
      {
        "command": "loom.scheduler.editCpuAffinity",
        "title": "Loom: Edit CPU Affinity..."
      },
      {
        "command": "loom.scheduler.editSpin",
        "title": "Loom: Edit Spin..."
      },
      {
        "command": "loom.scheduler.reassign",
        "title": "Loom: Reassign Module to Class..."
      },
      {
        "command": "loom.mappings.refresh",
        "title": "Loom: Refresh I/O Mappings",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.mappings.add",
        "title": "Loom: Add I/O Mapping...",
        "icon": "$(add)"
      },
      {
        "command": "loom.mappings.resolve",
        "title": "Loom: Resolve I/O Mappings",
        "icon": "$(sync)"
      },
      {
        "command": "loom.mappings.toggle",
        "title": "Loom: Toggle I/O Mapping"
      },
      {
        "command": "loom.mappings.delete",
        "title": "Loom: Delete I/O Mapping",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "loom.runtime.start",
          "when": "view == loom.modules && !loom.runtimeRunning",
          "group": "navigation@1"
        },
        {
          "command": "loom.runtime.stop",
          "when": "view == loom.modules && loom.runtimeRunning",
          "group": "navigation@1"
        },
        {
          "command": "loom.runtime.restart",
          "when": "view == loom.modules && loom.runtimeRunning",
          "group": "navigation@2"
        },
        {
          "command": "loom.runtime.selectProfile",
          "when": "view == loom.modules",
          "group": "navigation@2"
        },
        {
          "command": "loom.modules.manage",
          "when": "view == loom.modules",
          "group": "navigation@3"
        },
        {
          "command": "loom.runtime.attach",
          "when": "view == loom.modules",
          "group": "navigation@4"
        },
        {
          "command": "loom.modules.inspect",
          "when": "view == loom.modules",
          "group": "navigation@5"
        },
        {
          "command": "loom.modules.refresh",
          "when": "view == loom.modules",
          "group": "navigation@9"
        },
        {
          "command": "loom.scheduler.newClass",
          "when": "view == loom.scheduler",
          "group": "navigation@1"
        },
        {
          "command": "loom.scheduler.refresh",
          "when": "view == loom.scheduler",
          "group": "navigation@9"
        },
        {
          "command": "loom.mappings.add",
          "when": "view == loom.mappings",
          "group": "navigation@1"
        },
        {
          "command": "loom.mappings.resolve",
          "when": "view == loom.mappings",
          "group": "navigation@2"
        },
        {
          "command": "loom.mappings.refresh",
          "when": "view == loom.mappings",
          "group": "navigation@9"
        }
      ],
      "debug/variables/context": [
        {
          "command": "loom.modules.setValue",
          "when": "debugType == 'loom'",
          "group": "1_modify@1"
        }
      ],
      "view/item/context": [
        {
          "command": "loom.modules.openSource",
          "when": "view == loom.modules && viewItem == module",
          "group": "0_open@1"
        },
        {
          "command": "loom.modules.reload",
          "when": "view == loom.modules && viewItem == module",
          "group": "1_lifecycle@1"
        },
        {
          "command": "loom.modules.remove",
          "when": "view == loom.modules && viewItem == module",
          "group": "1_lifecycle@2"
        },
        {
          "command": "loom.modules.saveConfig",
          "when": "view == loom.modules && viewItem == module",
          "group": "2_config@1"
        },
        {
          "command": "loom.modules.loadConfig",
          "when": "view == loom.modules && viewItem == module",
          "group": "2_config@2"
        },
        {
          "command": "loom.bus.callService",
          "when": "view == loom.bus && viewItem == busService",
          "group": "1_call@1"
        },
        {
          "command": "loom.scheduler.editPeriod",
          "when": "view == loom.scheduler && viewItem == schedulerClass",
          "group": "1_edit@1"
        },
        {
          "command": "loom.scheduler.editPriority",
          "when": "view == loom.scheduler && viewItem == schedulerClass",
          "group": "1_edit@2"
        },
        {
          "command": "loom.scheduler.editCpuAffinity",
          "when": "view == loom.scheduler && viewItem == schedulerClass",
          "group": "1_edit@3"
        },
        {
          "command": "loom.scheduler.editSpin",
          "when": "view == loom.scheduler && viewItem == schedulerClass",
          "group": "1_edit@4"
        },
        {
          "command": "loom.scheduler.reassign",
          "when": "view == loom.scheduler && viewItem == schedulerMember",
          "group": "1_move@1"
        },
        {
          "command": "loom.mappings.toggle",
          "when": "view == loom.mappings && viewItem =~ /^mapping/",
          "group": "1_state@1"
        },
        {
          "command": "loom.mappings.delete",
          "when": "view == loom.mappings && viewItem =~ /^mapping/",
          "group": "1_state@2"
        }
      ],
      "commandPalette": [
        {
          "command": "loom.runtime.toggle",
          "when": "false"
        },
        {
          "command": "loom.modules.openDetail",
          "when": "false"
        },
        {
          "command": "loom.modules.setValue",
          "when": "false"
        }
      ]
    },
    "breakpoints": [],
    "debuggers": [
      {
        "type": "loom",
        "label": "Loom: Inspect Modules",
        "languages": [],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "url": {
                "type": "string",
                "description": "Loom server URL. Defaults to the loom.serverUrl setting.",
                "default": "http://localhost:8080"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "loom",
            "request": "attach",
            "name": "Loom: Inspect Modules"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Loom: Attach to running runtime",
            "description": "Attach to a running Loom runtime and surface modules in the Variables view.",
            "body": {
              "type": "loom",
              "request": "attach",
              "name": "Loom: Inspect Modules"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "loom.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the Loom HTTP/WebSocket server."
        },
        "loom.repoPath": {
          "type": "string",
          "default": "",
          "description": "Optional: path to a local Loom source checkout. When set, the runtime/module/data paths default to ${loom.repoPath}/output/loom, ${loom.repoPath}/output/modules, and ${loom.repoPath}/data respectively. Supports ${workspaceFolder}."
        },
        "loom.runtimeExecutable": {
          "type": "string",
          "default": "",
          "description": "Path to the loom binary. Set this directly, run \"Loom: Install Loom Runtime\" to download a release, or set loom.repoPath to derive from a source checkout. Supports ${workspaceFolder}."
        },
        "loom.runtimeProfile": {
          "type": "string",
          "enum": [
            "debug",
            "release"
          ],
          "default": "debug",
          "description": "Active runtime profile used for executable/module directory resolution. Use 'Loom: Select Runtime Profile...' to switch quickly."
        },
        "loom.runtimeExecutableDebug": {
          "type": "string",
          "default": "",
          "description": "Path to the Debug loom binary. Set automatically by 'Loom: Install Loom Runtime'."
        },
        "loom.runtimeExecutableRelease": {
          "type": "string",
          "default": "",
          "description": "Path to the Release loom binary. Set automatically by 'Loom: Install Loom Runtime'."
        },
        "loom.userModuleDir": {
          "type": "string",
          "default": "${workspaceFolder}/output/modules",
          "description": "User module directory — built/uploaded modules live here. Defaults to a workspace-local output/modules; the 'New Module Project' template pins this in .vscode/settings.json. Skipped when no workspace is open."
        },
        "loom.userModuleDirDebug": {
          "type": "string",
          "default": "${workspaceFolder}/output/modules/Debug",
          "description": "Debug user module directory. Checked before loom.userModuleDir when runtimeProfile=debug."
        },
        "loom.userModuleDirRelease": {
          "type": "string",
          "default": "${workspaceFolder}/output/modules/Release",
          "description": "Release user module directory. Checked before loom.userModuleDir when runtimeProfile=release."
        },
        "loom.systemModuleDir": {
          "type": "string",
          "default": "",
          "description": "System / example module directory bundled with the Loom release. Set automatically by 'Loom: Install Loom Runtime'."
        },
        "loom.systemModuleDirDebug": {
          "type": "string",
          "default": "",
          "description": "Debug system/example module directory bundled with the Loom release."
        },
        "loom.systemModuleDirRelease": {
          "type": "string",
          "default": "",
          "description": "Release system/example module directory bundled with the Loom release."
        },
        "loom.dataDir": {
          "type": "string",
          "default": "${workspaceFolder}/data",
          "description": "Config/recipe/instances persistence directory. Defaults to workspace-local data/ via ${workspaceFolder}. Falls back to ${loom.repoPath}/data when loom.repoPath is set, then to ~/.loom/data when no workspace is open."
        },
        "loom.releaseRepo": {
          "type": "string",
          "default": "Joshpolansky/Loom",
          "description": "GitHub repo (form 'owner/name') hosting Loom binary releases. Used by the 'Loom: Install Loom Runtime' command."
        },
        "loom.releaseAssetTemplate": {
          "type": "string",
          "default": "loom-{platform}-{arch}.tar.gz",
          "description": "Asset name template for the install command. {platform} expands to darwin/linux/win32 and {arch} to arm64/x64."
        },
        "loom.releaseAssetTemplateDebug": {
          "type": "string",
          "default": "loom-{platform}-{arch}-debug.tar.gz",
          "description": "Debug runtime asset template for install. Supports {platform}, {arch}, and {build}."
        },
        "loom.releaseAssetTemplateRelease": {
          "type": "string",
          "default": "loom-{platform}-{arch}.tar.gz",
          "description": "Release runtime asset template for install. Supports {platform}, {arch}, and {build}."
        },
        "loom.port": {
          "type": "number",
          "default": 8080,
          "description": "Port the runtime should bind to when started by the extension."
        },
        "loom.bindAddress": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Address the runtime should bind to. Default 127.0.0.1 keeps the HTTP/WebSocket API reachable only from the local machine; set 0.0.0.0 to expose it on the LAN."
        },
        "loom.debugAdapter": {
          "type": "string",
          "enum": [
            "lldb",
            "cppdbg"
          ],
          "default": "lldb",
          "description": "Native debug adapter for 'Debug Runtime'. 'lldb' uses CodeLLDB (vadimcn.vscode-lldb); 'cppdbg' uses Microsoft C/C++ (ms-vscode.cpptools)."
        },
        "loom.pollIntervalMs": {
          "type": "number",
          "default": 5000,
          "description": "How often to poll /api/modules while disconnected from the WebSocket."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc -p . --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "ws": "^8.20.0"
  }
}
