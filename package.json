{
  "name": "loomui",
  "displayName": "Loom",
  "description": "Side-panel UI and debug commands for the Loom runtime.",
  "version": "0.1.0",
  "publisher": "loom",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "activationEvents": [
    "onView:loom.modules",
    "onView:loom.scheduler",
    "onView:loom.bus",
    "onCommand:loom.runtime.start",
    "onCommand:loom.runtime.debug",
    "onCommand:loom.runtime.connect"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom.svg"
        }
      ]
    },
    "views": {
      "loom": [
        { "id": "loom.modules",   "name": "Modules" },
        { "id": "loom.scheduler", "name": "Scheduler" },
        { "id": "loom.bus",       "name": "Bus" }
      ]
    },
    "commands": [
      { "command": "loom.runtime.start",    "title": "Loom: Start Runtime",          "icon": "$(debug-start)"   },
      { "command": "loom.runtime.stop",     "title": "Loom: Stop Runtime",           "icon": "$(debug-stop)"    },
      { "command": "loom.runtime.restart",  "title": "Loom: Restart Runtime",        "icon": "$(debug-restart)" },
      { "command": "loom.runtime.debug",    "title": "Loom: Debug Runtime (Native)", "icon": "$(debug-alt)"     },
      { "command": "loom.runtime.toggle",   "title": "Loom: Toggle Runtime"          },
      { "command": "loom.runtime.connect",  "title": "Loom: Connect to Runtime..."   },

      { "command": "loom.modules.refresh",     "title": "Loom: Refresh Modules", "icon": "$(refresh)" },
      { "command": "loom.modules.openDetail",  "title": "Loom: Open Module Detail" },
      { "command": "loom.modules.instantiate", "title": "Loom: Instantiate Module...", "icon": "$(add)" },
      { "command": "loom.modules.remove",      "title": "Loom: Remove Module", "icon": "$(trash)" },
      { "command": "loom.modules.reload",      "title": "Loom: Reload Module", "icon": "$(refresh)" },
      { "command": "loom.modules.saveConfig",  "title": "Loom: Save Module Config" },
      { "command": "loom.modules.loadConfig",  "title": "Loom: Load Module Config from Disk" },
      { "command": "loom.modules.upload",      "title": "Loom: Upload Module..." },

      { "command": "loom.bus.callService",     "title": "Loom: Call Bus Service..." }
    ],
    "menus": {
      "view/title": [
        { "command": "loom.runtime.start",       "when": "view == loom.modules && !loom.runtimeRunning", "group": "navigation@1" },
        { "command": "loom.runtime.stop",        "when": "view == loom.modules && loom.runtimeRunning",  "group": "navigation@1" },
        { "command": "loom.runtime.restart",     "when": "view == loom.modules && loom.runtimeRunning",  "group": "navigation@2" },
        { "command": "loom.modules.instantiate", "when": "view == loom.modules", "group": "navigation@3" },
        { "command": "loom.modules.refresh",     "when": "view == loom.modules", "group": "navigation@9" }
      ],
      "view/item/context": [
        { "command": "loom.modules.reload",     "when": "view == loom.modules && viewItem == module", "group": "1_lifecycle@1" },
        { "command": "loom.modules.remove",     "when": "view == loom.modules && viewItem == module", "group": "1_lifecycle@2" },
        { "command": "loom.modules.saveConfig", "when": "view == loom.modules && viewItem == module", "group": "2_config@1" },
        { "command": "loom.modules.loadConfig", "when": "view == loom.modules && viewItem == module", "group": "2_config@2" }
      ],
      "commandPalette": [
        { "command": "loom.runtime.toggle",     "when": "false" },
        { "command": "loom.modules.openDetail", "when": "false" }
      ]
    },
    "configuration": {
      "title": "Loom",
      "properties": {
        "loom.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the Loom HTTP/WebSocket server."
        },
        "loom.repoPath": {
          "type": "string",
          "default": "${workspaceFolder}/../Loom",
          "description": "Path to the Loom source repository. Used to derive default runtime, module, and data paths. Supports ${workspaceFolder}."
        },
        "loom.runtimeExecutable": {
          "type": "string",
          "default": "",
          "description": "Path to the loom binary. If empty, defaults to ${loom.repoPath}/output/loom. Supports ${workspaceFolder}."
        },
        "loom.moduleDir": {
          "type": "string",
          "default": "",
          "description": "Module .so/.dylib directory. If empty, defaults to ${loom.repoPath}/output/modules."
        },
        "loom.dataDir": {
          "type": "string",
          "default": "",
          "description": "Config/recipe persistence directory. If empty, defaults to ${loom.repoPath}/data."
        },
        "loom.port": {
          "type": "number",
          "default": 8080,
          "description": "Port the runtime should bind to when started by the extension."
        },
        "loom.bindAddress": {
          "type": "string",
          "default": "0.0.0.0",
          "description": "Address the runtime should bind to."
        },
        "loom.debugAdapter": {
          "type": "string",
          "enum": ["lldb", "cppdbg"],
          "default": "lldb",
          "description": "Native debug adapter for 'Debug Runtime'. 'lldb' uses CodeLLDB (vadimcn.vscode-lldb); 'cppdbg' uses Microsoft C/C++ (ms-vscode.cpptools)."
        },
        "loom.pollIntervalMs": {
          "type": "number",
          "default": 5000,
          "description": "How often to poll /api/modules while disconnected from the WebSocket."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
